{
  "name": "jiva-farm-os",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib scripts src tests next.config.ts playwright.config.ts tailwind.config.ts vitest.config.ts --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:db": "node scripts/run-local-db-tests.mjs",
    "test:e2e": "node scripts/run-local-e2e.mjs",
    "check:env-contract": "node scripts/check-environment.mjs --example",
    "check:env-production": "node scripts/check-environment.mjs --production",
    "check:deployment-env": "node scripts/check-environment.mjs --deployment",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test:unit && npm run build && npm run check:bundle",
    "release:check": "npm run check:env-contract && npm run check:migrations && npm run verify && npm audit --omit=dev --audit-level=high",
    "release:smoke": "node scripts/smoke-deployment.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.45.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "8.5.16",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
